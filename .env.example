# MEC AUTO - Configuration
# Copier ce fichier vers .env et adapter les valeurs

# Base de données PostgreSQL
DATABASE_URL=postgresql://mecauser:mecapass@localhost:5432/mecaauto

# Serveur Flask
SECRET_KEY=changeme-securite-cle-aleatoire-32-caracteres
FLASK_ENV=production
FLASK_DEBUG=0

# Configuration SMTP (pour l'envoi des factures)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=atelier@lycee.fr
SMTP_PASSWORD=app-password-ou-mdp
SMTP_FROM=atelier@lycee.fr

# Configuration établissement (pour les factures)
ETABLISSEMENT_NOM="Lycée Professionnel Atelier"
ETABLISSEMENT_ADRESSE="123 Rue de l'École, 00000 Ville"
ETABLISSEMENT_TEL=0123456789
ETABLISSEMENT_EMAIL=atelier@lycee.fr