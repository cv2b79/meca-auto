# Configuration pour PostgreSQL
# Copier ce fichier vers .env et adapter les valeurs

# Base de données PostgreSQL
DATABASE_URL=postgresql://mecauser:motdepasse@localhost/mecaauto

# Clé secrète (générer une clé aléatoire pour production)
SECRET_KEY=votre-cle-secrete-a-changer-en-production

# SMTP pour les factures (optionnel)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER= votre-email@gmail.com
SMTP_PASSWORD=app-password

# Infos établissement
ETABLISSEMENT_NOM=Lycée Professionnel
ETABLISSEMENT_ADRESSE=123 Rue du Lycée
ETABLISSEMENT_TEL=01 23 45 67 89
ETABLISSEMENT_EMAIL=atelier@lycee.fr